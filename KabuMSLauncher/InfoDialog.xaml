<Window x:Class="KabuMSLauncher.InfoDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="情報"
        Height="460" Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BgSoft}"
        FontFamily="Yu Gothic UI, Meiryo, sans-serif"
        ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BrandPrimary}" Padding="20,16">
            <StackPanel Orientation="Horizontal">
                <Image Source="Assets/logo.png" Width="32" Height="32" Margin="0,0,12,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="HeaderTextBlock" Foreground="White" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="20,18" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="BodyTextBlock" FontSize="13" Foreground="#1C1C1C" TextWrapping="Wrap" LineHeight="22"/>
                <TextBlock x:Name="LinkBlock" FontSize="13" Margin="0,14,0,0">
                    <Hyperlink x:Name="LinkHyperlink" Click="LinkHyperlink_Click">
                        <Run x:Name="LinkRunText"/>
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="16,12">
            <Button Content="OK" Width="100" Height="32" HorizontalAlignment="Right" Click="OkButton_Click"
                    Background="{StaticResource BrandPrimary}" Foreground="White" BorderThickness="0" Cursor="Hand"/>
        </Border>
    </Grid>
</Window>
