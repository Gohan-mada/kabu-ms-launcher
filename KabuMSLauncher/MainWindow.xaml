<Window x:Class="KabuMSLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="かぶ自動LOGIN｜MarketspeedⅡ 自動起動アプリ"
        Height="680" Width="440"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgSoft}"
        ResizeMode="CanMinimize"
        Icon="Assets/app.ico"
        FontFamily="Yu Gothic UI, Meiryo, sans-serif">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource BrandPrimary}" Padding="20,16">
            <StackPanel Orientation="Horizontal">
                <Image Source="Assets/logo.png" Width="44" Height="44" Margin="0,0,14,0" VerticalAlignment="Center"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="かぶ自動LOGIN" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,2"/>
                    <TextBlock Text="MarketspeedⅡ 自動起動アプリ" Foreground="#9FB4D1" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Form -->
        <StackPanel Grid.Row="1" Margin="24,22,24,0">
            <TextBlock Text="ログインID" Foreground="{StaticResource TextDark}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <TextBox x:Name="LoginIdBox" Style="{StaticResource TextField}" Margin="0,0,0,16"/>

            <TextBlock Text="パスワード" Foreground="{StaticResource TextDark}" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
            <Grid Margin="0,0,0,12">
                <PasswordBox x:Name="PasswordBox" Style="{StaticResource TextField}"/>
                <TextBox x:Name="PasswordPlainBox" Style="{StaticResource TextField}" Visibility="Collapsed"/>
            </Grid>

            <CheckBox x:Name="ShowPasswordCheck" Content="パスワードを表示" Margin="0,0,0,16" Checked="ShowPasswordCheck_Toggled" Unchecked="ShowPasswordCheck_Toggled"/>

            <CheckBox x:Name="SaveCredentialsCheck" Content="ID・パスワードを保存する（このPCでのみ使用、DPAPI暗号化）" IsChecked="True" Margin="0,0,0,8" Foreground="{StaticResource TextDark}"/>
            <CheckBox x:Name="AutoStartCheck" Content="Windows起動時にこのランチャーを自動起動" Margin="0,0,0,20" Foreground="{StaticResource TextDark}"/>

            <Button x:Name="LaunchButton" Content="⚡ MarketspeedⅡ を起動する" Style="{StaticResource PrimaryButton}" Click="LaunchButton_Click" Height="48"/>

            <TextBlock x:Name="StatusText" Text="" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,14,0,10" TextAlignment="Center" TextWrapping="Wrap"/>

            <Border Background="#FFF7ED" BorderBrush="#FDBA74" BorderThickness="1" CornerRadius="6" Padding="14,12" Margin="0,8,0,14">
                <StackPanel>
                    <TextBlock FontSize="11" Foreground="#9A3412" FontWeight="SemiBold" Margin="0,0,0,4">
                        💡 投資にAIをもっと活用したい方へ
                    </TextBlock>
                    <TextBlock FontSize="11" Foreground="#7C2D12" TextWrapping="Wrap" Margin="0,0,0,10">
                        かぶ自動化LABでは、銘柄スクリーニング・デイトレ補助AI・自動売買botを「使える→わかる→自分で作れる」の3段階で学べる講座を提供しています。
                    </TextBlock>
                    <Button x:Name="LabCtaButton" Content="かぶ自動化LAB を見る →" Click="LabCtaButton_Click" HorizontalAlignment="Left"
                            Background="Transparent" Foreground="#9A3412" BorderBrush="#9A3412" BorderThickness="1" Padding="12,6" FontSize="12" Cursor="Hand"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Footer -->
        <Border Grid.Row="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,1,0,0" Padding="20,12">
            <Grid>
                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" FontSize="11">
                    <Run Text="Powered by "/>
                    <Run Text="かぶ自動化LAB" FontWeight="SemiBold"/>
                </TextBlock>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="HelpButton" Content="使い方" Click="HelpButton_Click" Background="Transparent" BorderThickness="0" Foreground="#0F2A4A" Cursor="Hand" Padding="6,2" FontSize="11"/>
                    <Button x:Name="AboutButton" Content="バージョン情報" Click="AboutButton_Click" Background="Transparent" BorderThickness="0" Foreground="#0F2A4A" Cursor="Hand" Padding="6,2" FontSize="11" Margin="6,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
